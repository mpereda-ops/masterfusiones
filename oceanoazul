<script>
// ══════════════════════════════════
// SCORM DRIVER
// ══════════════════════════════════
const SCORM = {
  initialized: false,
  
  init() {
    try {
      const API = this.findAPI(window);
      if (API) {
        API.Initialize('');
        this.initialized = true;
        console.log('SCORM initialized');
      }
    } catch (e) {
      console.log('SCORM not available (standalone mode)');
    }
    return this.initialized;
  },
  
  findAPI(win) {
    let attempts = 0;
    while (win && attempts < 7) {
      if (win.API_1484_11) return win.API_1484_11;
      if (win.API) return win.API;
      if (win.parent && win.parent !== win) {
        attempts++;
        win = win.parent;
      } else {
        break;
      }
    }
    return null;
  },
  
  setValue(key, value) {
    if (!this.initialized) return;
    try {
      const API = this.findAPI(window);
      if (API) API.SetValue(key, value);
    } catch (e) {
      console.log('SCORM setValue error:', e);
    }
  },
  
  setScore(score) {
    this.setValue('cmi.score.raw', score);
    this.setValue('cmi.score.min', '0');
    this.setValue('cmi.score.max', '100');
  },
  
  setCompleted() {
    this.setValue('cmi.completion_status', 'completed');
    this.setValue('cmi.success_status', 'passed');
  },
  
  commit() {
    try {
      const API = this.findAPI(window);
      if (API) API.Commit('');
    } catch (e) {
      console.log('SCORM commit error:', e);
    }
  },
  
  finish() {
    try {
      const API = this.findAPI(window);
      if (API) {
        this.commit();
        API.Terminate('');
      }
    } catch (e) {
      console.log('SCORM finish error:', e);
    }
  }
};

// ══════════════════════════════════
// ESTADO GLOBAL
// ══════════════════════════════════
const state = {
  phase: 1,
  industria: '',
  frustraciones: '',
  conceptos: '',
  validacion: '',
  sessionStart: null,
  timerInterval: null,
  submitting: false
};

const API_KEY = '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';

// INIT
function iniciarSimulador() {
  SCORM.init();
  state.sessionStart = new Date();
  mostrarPantalla('screen-main');
  iniciarTimer();
  renderizarFase(1);
}

function iniciarTimer() {
  state.timerInterval = setInterval(() => {
    const elapsed = Math.floor((new Date() - state.sessionStart) / 1000);
    const m = Math.floor(elapsed / 60).toString().padStart(2, '0');
    const s = (elapsed % 60).toString().padStart(2, '0');
    document.getElementById('timer').textContent = `${m}:${s}`;
  }, 1000);
}

function mostrarPantalla(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function actualizarTracker(fase) {
  for (let i = 1; i <= 4; i++) {
    const tracker = document.getElementById(`tracker-${i}`);
    tracker.classList.remove('active', 'completed');
    if (i < fase) tracker.classList.add('completed');
    if (i === fase) tracker.classList.add('active');
  }
  document.getElementById('current-phase').textContent = `${fase} de 4`;
}

// RENDER FASES
function renderizarFase(fase) {
  state.phase = fase;
  actualizarTracker(fase);
  
  const canvas = document.getElementById('canvas-main');
  
  if (fase === 1) {
    canvas.innerHTML = `
      <div class="phase-container">
        <div class="phase-header">
          <div class="phase-label">◆ Fase 1 de 4</div>
          <h2 class="phase-title">Selecciona tu Industria</h2>
        </div>
        
        <div class="instruction-card">
          <div class="instruction-card-title">◆ Objetivo</div>
          <div class="instruction-card-text">
            Elige una industria tradicional que lleve décadas sin cambios significativos. Criterio: si tu abuela conocía la industria igual que tú, es buena candidata.
          </div>
        </div>
        
        <div class="input-group">
          <div class="input-label">¿Qué industria quieres analizar?</div>
          <input type="text" id="input-industria" class="input-field" placeholder="Ejemplo: Peluquerías, Lavanderías, Notarías, Gimnasios..." />
        </div>
        
        <button class="btn-action" onclick="ejecutarFase1()">Analizar Frustraciones →</button>
      </div>
    `;
  } else if (fase === 2) {
    canvas.innerHTML = `
      <div class="phase-container">
        <div class="phase-header">
          <div class="phase-label">◆ Fase 2 de 4</div>
          <h2 class="phase-title">Frustraciones Identificadas</h2>
        </div>
        
        <div class="result-card">${state.frustraciones}</div>
        
        <div id="thinking-2" class="thinking-indicator">
          <div class="thinking-spinner"></div>
          <div class="thinking-text">Claude está generando conceptos...</div>
        </div>
        
        <div id="error-2" class="error-card hidden"></div>
        
        <button class="btn-action" onclick="ejecutarFase2()">Generar Conceptos Océano Azul →</button>
      </div>
    `;
  } else if (fase === 3) {
    canvas.innerHTML = `
      <div class="phase-container">
        <div class="phase-header">
          <div class="phase-label">◆ Fase 3 de 4</div>
          <h2 class="phase-title">Conceptos de Océano Azul</h2>
        </div>
        
        <div class="result-card">${state.conceptos}</div>
        
        <div class="input-group">
          <div class="input-label">¿Qué concepto quieres validar? (1, 2 o 3)</div>
          <input type="number" id="input-concepto" class="input-field" min="1" max="3" value="1" />
        </div>
        
        <div id="thinking-3" class="thinking-indicator">
          <div class="thinking-spinner"></div>
          <div class="thinking-text">Claude está diseñando experimentos...</div>
        </div>
        
        <div id="error-3" class="error-card hidden"></div>
        
        <button class="btn-action" onclick="ejecutarFase3()">Diseñar Experimentos →</button>
      </div>
    `;
  } else if (fase === 4) {
    canvas.innerHTML = `
      <div class="phase-container">
        <div class="phase-header">
          <div class="phase-label">◆ Fase 4 de 4</div>
          <h2 class="phase-title">Experimentos de Validación</h2>
        </div>
        
        <div class="result-card">${state.validacion}</div>
        
        <div class="instruction-card">
          <div class="instruction-card-title">◆ Enviar Resultados</div>
          <div class="instruction-card-text">
            Introduce tu email para recibir un resumen completo de tu exploración de océano azul.
          </div>
        </div>
        
        <div class="input-group">
          <div class="input-label">Tu email</div>
          <input type="email" id="input-email" class="input-field" placeholder="tu@email.com" />
        </div>
        
        <div id="success-email" class="success-card hidden"></div>
        <div id="error-email" class="error-card hidden"></div>
        
        <button class="btn-action" onclick="enviarPorEmail()">Enviar Resultados por Email →</button>
        <button class="btn-secondary" onclick="reiniciarSimulador()">Nueva Búsqueda</button>
      </div>
    `;
  }
}

// CLAUDE API
async function llamarClaude(prompt) {
  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': API_KEY,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-direct-browser-access': 'true'
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 2500,
      messages: [{ role: 'user', content: prompt }]
    })
  });

  if (!response.ok) {
    const errorData = await response.json();
    throw new Error(`API Error ${response.status}: ${errorData.error?.message || 'Unknown error'}`);
  }
  
  const data = await response.json();
  return data.content[0].text;
}

// FASE 1
async function ejecutarFase1() {
  const industria = document.getElementById('input-industria').value.trim();
  if (!industria) {
    alert('Por favor, introduce una industria');
    return;
  }

  state.industria = industria;

  const prompt = `Analiza las quejas y frustraciones de usuarios de ${industria} en España en los últimos 3 años. 

Ignora problemas obvios como precio o calidad básica del servicio. 

Enfócate en identificar frustraciones EMOCIONALES recurrentes que los usuarios expresan pero que raramente son abordadas por soluciones existentes. 

Presenta las 3-5 frustraciones más importantes de forma clara y concisa.`;

  try {
    document.querySelector('.phase-container').innerHTML += `
      <div id="thinking-1" class="thinking-indicator visible">
        <div class="thinking-spinner"></div>
        <div class="thinking-text">Claude está analizando...</div>
      </div>
    `;

    const resultado = await llamarClaude(prompt);
    state.frustraciones = resultado;
    SCORM.setValue('cmi.suspend_data', JSON.stringify(state));
    renderizarFase(2);
  } catch (error) {
    alert(`Error: ${error.message}`);
  }
}

// FASE 2
async function ejecutarFase2() {
  document.getElementById('thinking-2').classList.add('visible');

  const prompt = `Basándote en estas frustraciones sobre ${state.industria}:

${state.frustraciones}

Genera 3 conceptos de negocio innovadores que NO compitan directamente.

Para cada concepto: nombre, frustraciones que elimina, cómo cambia reglas, por qué difícil replicar.

Numera: Concepto 1, Concepto 2, Concepto 3.`;

  try {
    const resultado = await llamarClaude(prompt);
    state.conceptos = resultado;
    SCORM.setValue('cmi.suspend_data', JSON.stringify(state));
    renderizarFase(3);
  } catch (error) {
    document.getElementById('thinking-2').classList.remove('visible');
    document.getElementById('error-2').textContent = `Error: ${error.message}`;
    document.getElementById('error-2').classList.remove('hidden');
  }
}

// FASE 3
async function ejecutarFase3() {
  const conceptoNum = document.getElementById('input-concepto').value;
  document.getElementById('thinking-3').classList.add('visible');

  const prompt = `Concepto ${conceptoNum}:

${state.conceptos}

Diseña 3 experimentos validación: <5.000€, <4 semanas.

Para cada: qué valida, cómo ejecutar, coste, tiempo, métrica, éxito/fracaso.`;

  try {
    const resultado = await llamarClaude(prompt);
    state.validacion = resultado;
    SCORM.setValue('cmi.suspend_data', JSON.stringify(state));
    SCORM.setCompleted();
    SCORM.setScore(100);
    SCORM.commit();
    renderizarFase(4);
  } catch (error) {
    document.getElementById('thinking-3').classList.remove('visible');
    document.getElementById('error-3').textContent = `Error: ${error.message}`;
    document.getElementById('error-3').classList.remove('hidden');
  }
}

// ENVIAR POR EMAIL
async function enviarPorEmail() {
  const email = document.getElementById('input-email').value.trim();
  if (!email || !email.includes('@')) {
    alert('Por favor, introduce un email válido');
    return;
  }

  const contenido = `
OCÉANO AZUL - RESULTADOS
========================

INDUSTRIA ANALIZADA: ${state.industria}

FRUSTRACIONES IDENTIFICADAS:
${state.frustraciones}

CONCEPTOS OCÉANO AZUL:
${state.conceptos}

EXPERIMENTOS DE VALIDACIÓN:
${state.validacion}

---
SimulabAI | Universidad de Salamanca
Prof. Jorge Matías-Pereda
  `.trim();

  try {
    // FormSubmit.co - servicio gratuito de envío de emails
    const formData = new FormData();
    formData.append('email', email);
    formData.append('asunto', `Océano Azul: ${state.industria}`);
    formData.append('mensaje', contenido);

    const response = await fetch('https://formsubmit.co/ajax/' + email, {
      method: 'POST',
      body: formData
    });

    if (response.ok) {
      document.getElementById('success-email').textContent = '✅ Email enviado exitosamente. Revisa tu bandeja de entrada.';
      document.getElementById('success-email').classList.remove('hidden');
      document.getElementById('input-email').disabled = true;
    } else {
      throw new Error('Error al enviar');
    }
  } catch (error) {
    document.getElementById('error-email').textContent = `Error al enviar email. Copia manualmente los resultados arriba.`;
    document.getElementById('error-email').classList.remove('hidden');
  }
}

function reiniciarSimulador() {
  state.phase = 1;
  state.industria = '';
  state.frustraciones = '';
  state.conceptos = '';
  state.validacion = '';
  renderizarFase(1);
}
